*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.pdb
*.ilk
*.exp

# -----------------------------------------------------------------------------
# Executables
# -----------------------------------------------------------------------------
*.exe
*.out
*.app
*.bin

# -----------------------------------------------------------------------------
